{
  "name": "takken-rpg",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "patch-package || true",
    "dev": "next dev",
    "build": "next build",
    "build:ios": "ts-node scripts/release/build-ios.ts",
    "start": "next start",
    "lint": "eslint app components lib middleware.ts next.config.mjs",
    "test:env": "ts-node -r dotenv/config scripts/test/env.ts",
    "test:server-boundaries": "ts-node scripts/test/server-import-boundaries.ts",
    "test:question-dedupe": "ts-node scripts/test/question-dedupe.ts",
    "lint:strict": "npm run lint -- --max-warnings=0",
    "emulators": "node scripts/start-emulators.js",
    "dev:emulator": "concurrently \"npm run emulators\" \"npm run dev\"",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:e2e:smoke": "playwright test tests/e2e/homepage.spec.ts tests/e2e/auth.spec.ts --project=chromium",
    "check-env": "node -r dotenv/config -r ts-node/register scripts/check/env.ts",
    "check:production-env": "ts-node scripts/check/production-env.ts",
    "generate:questions": "node scripts/generate/questions.js",
    "integrate:questions": "ts-node scripts/integrate/questions.ts",
    "generate:all": "node scripts/generate/batch-all.js",
    "test:functions": "ts-node scripts/test/firebase-functions.ts",
    "deploy:functions": "bash scripts/deploy/deploy-functions.sh",
    "deploy:functions:win": "call scripts/deploy/deploy-functions.bat",
    "duplicate:questions": "ts-node scripts/check/duplicates.ts",
    "check:questions": "ts-node scripts/check/question-counts.ts",
    "check:app-store": "ts-node scripts/test/app-store-safety.ts",
    "check:subscription-copy": "ts-node scripts/test/subscription-copy-consistency.ts",
    "verify:release": "npm run lint:strict && npm run check-env && npm run check:questions && npm run duplicate:questions && npm run check:question-quality && npm run check:app-store && npm run check:subscription-copy && npm run build",
    "verify:ios": "npm run check:app-store && npm run build:ios",
    "verify:production-env": "ts-node scripts/check/production-env.ts",
    "release:preflight": "npm run verify:release && npm run verify:ios",
    "release:production": "npm run verify:production-env && npm run verify:release",
    "bump:ios-build": "ts-node scripts/release/bump-ios-build.ts",
    "bump:ios-build:dry": "ts-node scripts/release/bump-ios-build.ts --dry-run",
    "check:subscription": "ts-node scripts/check-subscription-data.ts",
    "check:webhook": "ts-node scripts/check-stripe-webhook-events.ts",
    "verify:webhook": "ts-node scripts/check-stripe-webhook-events.ts && ts-node scripts/check-subscription-data.ts",
    "generate:prediction": "ts-node scripts/generate/generate-prediction-questions.ts",
    "generate:prediction:takkengyouhou": "ts-node scripts/generate/generate-prediction-questions.ts takkengyouhou",
    "generate:prediction:minpou": "ts-node scripts/generate/generate-prediction-questions.ts minpou",
    "generate:prediction:hourei": "ts-node scripts/generate/generate-prediction-questions.ts hourei",
    "generate:prediction:zeihou": "ts-node scripts/generate/generate-prediction-questions.ts zeihou",
    "test:prediction": "ts-node scripts/generate/test-prediction.ts",
    "integrate:prediction": "ts-node scripts/integrate/integrate-prediction-questions.ts",
    "test:question-source-locator": "ts-node scripts/test/question-source-locator.ts",
    "test:duplicate-report": "ts-node scripts/test/duplicate-report.ts",
    "duplicate:questions:report": "ts-node scripts/check/duplicates.ts --report docs/duplicate-questions-report.md",
    "test:question-quality-utils": "ts-node scripts/test/question-quality-utils.ts",
    "test:error-reporter": "ts-node scripts/test/error-reporter.ts",
    "test:stripe-webhook-idempotency": "ts-node scripts/test/stripe-webhook-idempotency.ts",
    "test:ai-fallback": "ts-node scripts/test/ai-fallback.ts",
    "test:version-check": "ts-node scripts/test/version-check.ts",
    "test:server-ai-provider": "ts-node scripts/test/server-ai-provider.ts",
    "test:trusted-origin": "ts-node scripts/test/trusted-origin.ts",
    "check:question-quality": "ts-node scripts/check/question-quality.ts",
    "check:question-content": "ts-node scripts/check/question-content-validator.ts",
    "check:question-content:all": "ts-node scripts/check/question-content-validator.ts --all"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.9.1",
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "^8.0.1",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/ios": "^8.0.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@google/generative-ai": "^0.2.1",
    "@sentry/nextjs": "^10.54.0",
    "@stripe/stripe-js": "^7.8.0",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@types/crypto-js": "^4.2.2",
    "capacitor-plugin-app-tracking-transparency": "^2.0.5",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.3.0",
    "firebase": "^10.7.1",
    "firebase-admin": "^13.10.0",
    "framer-motion": "^12.23.12",
    "next": "^15.5.16",
    "openai": "^4.20.1",
    "react": "^18",
    "react-dom": "^18",
    "react-firebase-hooks": "^5.1.1",
    "stripe": "^18.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^2.1.4",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/firebase": "^2.4.32",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.11",
    "@types/puppeteer": "^5.4.7",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "concurrently": "^8.2.2",
    "dotenv": "^17.2.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.16",
    "patch-package": "^8.0.1",
    "postcss": "8.5.15",
    "puppeteer": "^24.16.2",
    "sharp": "^0.34.4",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "canvas": "^3.2.0"
  },
  "overrides": {
    "@next/eslint-plugin-next": {
      "glob": "10.5.0"
    },
    "postcss": "8.5.15",
    "undici": "6.26.0",
    "uuid": "11.1.1"
  }
}
